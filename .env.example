# PostgreSQL connection string from Vercel Postgres dashboard
POSTGRES_URL=

# Your deployed Vercel app URL (e.g. https://chaya.vercel.app)
# Used for bKash payment callback. Leave blank for local dev.
APP_URL=

# bKash credentials (use sandbox values for testing)
BKASH_APP_KEY=sandboxTokenizedUser02AppId
BKASH_APP_SECRET=sandboxTokenizedUser02AppSecret
BKASH_USERNAME=sandboxTokenizedUser02
BKASH_PASSWORD=sandboxTokenizedUser02Pass
